<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Nova City — AAA Environment</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { background: #000; overflow: hidden; font-family: 'Segoe UI', system-ui, sans-serif; }
  #gameCanvas { width: 100vw; height: 100vh; display: block; touch-action: none; outline: none; }

  /* ── BOOT SCREEN ── */
  #boot {
    position: fixed; inset: 0; z-index: 100;
    background: linear-gradient(135deg, #0a0800 0%, #1a1000 50%, #0a0800 100%);
    display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 24px;
  }
  #boot .logo {
    font-size: 3.2rem; font-weight: 900; letter-spacing: .3em; color: #f5c842;
    text-transform: uppercase; font-family: 'Segoe UI', system-ui, sans-serif;
    text-shadow: 0 0 40px rgba(245,200,66,0.4), 0 0 80px rgba(245,200,66,0.15);
  }
  #boot .sub { color: rgba(245,200,66,0.45); font-size: .78rem; letter-spacing: .25em; text-transform: uppercase; font-family: monospace; }
  #bootMsg { color: rgba(255,255,255,0.35); font-size: .78rem; font-family: monospace; letter-spacing: .12em; }
  .spinner {
    width: 48px; height: 48px;
    border: 2px solid rgba(245,200,66,0.15); border-top-color: #f5c842;
    border-radius: 50%; animation: spin .9s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* ── HUD BASE ── */
  #hud { position: fixed; inset: 0; pointer-events: none; z-index: 10; display: flex; flex-direction: column; justify-content: space-between; padding: 20px 24px; }
  .hud-panel {
    background: rgba(8,6,4,0.72);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(245,200,66,0.12);
    border-radius: 10px;
  }

  /* ── TOP LEFT: OBJECTIVE ── */
  #objective { padding: 14px 18px; border-left: 2px solid #f5c842; max-width: 300px; }
  #objective .label { font-size: 9px; letter-spacing: .2em; text-transform: uppercase; color: #f5c842; font-weight: 700; margin-bottom: 5px; font-family: monospace; }
  #objective .title { font-size: 1.05rem; color: #f5f0e8; font-weight: 600; }
  #objective .sub { font-size: .72rem; color: rgba(245,240,232,0.5); margin-top: 4px; line-height: 1.5; }

  /* ── TOP RIGHT: STATS ── */
  #stats { display: flex; flex-direction: column; gap: 8px; align-items: flex-end; }
  .stat-pill {
    padding: 7px 14px; border-radius: 20px;
    display: flex; align-items: center; gap: 9px;
    background: rgba(8,6,4,0.72); border: 1px solid rgba(245,200,66,0.12);
    backdrop-filter: blur(12px);
  }
  .stat-pill .icon { font-size: 1rem; }
  .stat-pill .val { font-size: 1rem; font-weight: 700; color: #f5f0e8; font-family: monospace; letter-spacing: .05em; min-width: 68px; text-align: right; }
  #healthWrap { display: flex; align-items: center; gap: 9px; padding: 7px 14px; border-radius: 20px; background: rgba(8,6,4,0.72); border: 1px solid rgba(245,200,66,0.12); backdrop-filter: blur(12px); }
  #healthBar { width: 100px; height: 8px; background: rgba(255,255,255,0.08); border-radius: 4px; overflow: hidden; }
  #healthFill { height: 100%; width: 100%; background: linear-gradient(90deg, #e05555, #ff8888); border-radius: 4px; transition: width .3s; }
  #staminaWrap { display: flex; align-items: center; gap: 9px; padding: 7px 14px; border-radius: 20px; background: rgba(8,6,4,0.72); border: 1px solid rgba(245,200,66,0.12); backdrop-filter: blur(12px); }
  #staminaBar { width: 80px; height: 6px; background: rgba(255,255,255,0.08); border-radius: 3px; overflow: hidden; }
  #staminaFill { height: 100%; width: 100%; background: linear-gradient(90deg, #c8a020, #f5c842); border-radius: 3px; transition: width .15s; }
  #speedBox { padding: 7px 14px; border-radius: 20px; background: rgba(8,6,4,0.72); border: 1px solid rgba(245,200,66,0.12); backdrop-filter: blur(12px); font-family: monospace; font-size: .82rem; color: rgba(245,240,232,0.45); }
  #speedBox span { color: #f5c842; font-weight: 700; }

  /* ── BOTTOM LEFT: MINIMAP ── */
  #minimap { width: 170px; height: 170px; border-radius: 50%; border: 1px solid rgba(245,200,66,0.2); background: #060402; position: relative; overflow: hidden; box-shadow: 0 0 0 4px rgba(245,200,66,0.05), 0 8px 32px rgba(0,0,0,0.6); }
  #minimapCanvas { width: 100%; height: 100%; display: block; }
  #minimapDot { position: absolute; width: 8px; height: 8px; background: #f5c842; border-radius: 50%; top: 50%; left: 50%; transform: translate(-50%,-50%); box-shadow: 0 0 10px #f5c842; z-index: 2; }

  /* ── BOTTOM RIGHT: CONTROLS ── */
  #controls { padding: 12px 16px; font-family: monospace; font-size: .75rem; color: rgba(245,240,232,0.4); }
  #controls .ctitle { color: #f5c842; font-weight: 700; margin-bottom: 8px; text-transform: uppercase; font-size: .68rem; letter-spacing: .12em; border-bottom: 1px solid rgba(245,200,66,0.12); padding-bottom: 6px; }
  .ctrl-row { display: flex; justify-content: space-between; gap: 18px; padding: 2px 0; }
  .ctrl-row .key { color: rgba(245,240,232,0.8); font-weight: 700; background: rgba(255,255,255,0.06); padding: 1px 6px; border-radius: 3px; border: 1px solid rgba(255,255,255,0.1); }

  /* ── SPRINT INDICATOR ── */
  #sprintTag { position: fixed; bottom: 200px; left: 24px; z-index: 10; padding: 5px 14px; border-radius: 16px; background: rgba(245,200,66,0.12); border: 1px solid rgba(245,200,66,0.35); color: #f5c842; font-size: .72rem; font-family: monospace; font-weight: 700; letter-spacing: .12em; opacity: 0; transition: opacity .2s; }

  /* ── DAY TIME BADGE ── */
  #timeBadge { position: fixed; top: 20px; left: 50%; transform: translateX(-50%); z-index: 10; padding: 6px 16px; border-radius: 16px; background: rgba(8,6,4,0.72); border: 1px solid rgba(245,200,66,0.12); backdrop-filter: blur(12px); font-family: monospace; font-size: .78rem; color: rgba(245,240,232,0.45); }
  #timeBadge span { color: #f5f0e8; font-weight: 700; }

  /* ── PHASE BADGE ── */
  #phaseBadge { position: fixed; top: 20px; right: 24px; z-index: 10; padding: 6px 14px; border-radius: 6px; background: rgba(245,200,66,0.1); border: 1px solid rgba(245,200,66,0.25); font-family: monospace; font-size: .68rem; color: #f5c842; letter-spacing: .14em; font-weight: 700; text-transform: uppercase; }

  /* ── WANTED BADGE ── */
  #wantedBadge { position: fixed; top: 52px; right: 24px; z-index: 10; padding: 5px 14px; border-radius: 6px; background: rgba(200,30,30,.08); border: 1px solid rgba(200,30,30,.2); font-family: monospace; font-size: 1.1rem; color: rgba(245,240,232,0.25); letter-spacing: 0.08em; transition: all 0.3s ease; }
  .wanted-active { color: #ef4444 !important; text-shadow: 0 0 8px rgba(239,68,68,0.7) !important; }

  #hud-top { display: flex; justify-content: space-between; align-items: flex-start; }
  #hud-bottom { display: flex; justify-content: space-between; align-items: flex-end; }
</style>
</head>
<body>

<!-- Boot Screen -->
<div id="boot">
  <div class="spinner"></div>
  <div class="logo">Nova City</div>
  <div class="sub">AAA Environment · UE5-Style Rendering</div>
  <p id="bootMsg">Initializing Engine...</p>
</div>

<!-- Game Canvas -->
<canvas id="gameCanvas" tabindex="0"></canvas>

<!-- HUD -->
<div id="hud">
  <div id="hud-top">
    <div class="hud-panel" id="objective">
      <div class="label">Mission Objective</div>
      <div class="title">Explore Nova City</div>
      <div class="sub" id="objSub">Navigate the golden-hour cityscape. Find the yellow beacon.</div>
    </div>
    <div id="stats">
      <div class="stat-pill"><span class="icon">💰</span><span class="val" id="moneyVal">$4,250</span></div>
      <div id="healthWrap"><span class="icon">❤️</span><div id="healthBar"><div id="healthFill"></div></div></div>
      <div id="staminaWrap"><span class="icon">⚡</span><div id="staminaBar"><div id="staminaFill"></div></div></div>
      <div id="speedBox">SPD <span id="spdVal">0</span> km/h</div>
    </div>
  </div>
  <div id="hud-bottom">
    <div id="minimap"><canvas id="minimapCanvas" width="170" height="170"></canvas><div id="minimapDot"></div></div>
    <div class="hud-panel" id="controls">
      <div class="ctitle">Controls</div>
      <div class="ctrl-row"><span>Move</span><span class="key">W A S D</span></div>
      <div class="ctrl-row"><span>Sprint</span><span class="key">SHIFT</span></div>
      <div class="ctrl-row"><span>Jump</span><span class="key">SPACE</span></div>
      <div class="ctrl-row"><span>Car</span><span class="key">E</span></div>
      <div class="ctrl-row"><span>Camera</span><span class="key">DRAG</span></div>
    </div>
  </div>
</div>

<div id="sprintTag">SPRINTING</div>
<div id="timeBadge">☀️ <span id="timeStr">14:00</span></div>
<div id="phaseBadge">Nova City · AAA Build</div>
<div id="wantedBadge">★★★★★</div>

<!-- Babylon.js via CDN -->
<script src="https://cdn.babylonjs.com/babylon.js"></script>
<script src="https://cdn.babylonjs.com/loaders/babylonjs.loaders.min.js"></script>
<script src="https://cdn.babylonjs.com/materialsLibrary/babylonjs.materials.min.js"></script>
<script src="https://cdn.babylonjs.com/havok/HavokPhysics_umd.js"></script>
<script src="https://cdn.babylonjs.com/proceduralTexturesLibrary/babylonjs.proceduralTextures.min.js"></script>

<script type="module">
import { bootstrap } from '/src/game/main.js';

(async () => {
  const bootMsg = document.getElementById('bootMsg');
  const bootEl  = document.getElementById('boot');
  const canvas  = document.getElementById('gameCanvas');

  try {
    await bootstrap(canvas, bootMsg);

    // Hide Boot Screen
    bootMsg.textContent = 'Ready!';
    await new Promise(r => setTimeout(r, 380));
    bootEl.style.transition = 'opacity .65s';
    bootEl.style.opacity = '0';
    setTimeout(() => bootEl.style.display = 'none', 700);
    canvas.focus();
  } catch (err) {
    bootMsg.textContent = 'ERROR: ' + err.message;
    console.error(err);
  }
})();
</script>
</body>
</html>
