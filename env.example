rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }

    function isValidUser(data, isCreate) {
      return data.keys().hasAll(['uid', 'username', 'wins', 'losses', 'kills', 'deaths', 'rankPoints', 'createdAt']) &&
        (isCreate ? data.keys().size() == 8 : true) &&
        data.uid is string && data.uid.size() <= 128 && data.uid == request.auth.uid &&
        data.username is string && data.username.size() >= 3 && data.username.size() <= 64 &&
        data.wins is number &&
        data.losses is number &&
        data.kills is number &&
        data.deaths is number &&
        data.rankPoints is number &&
        data.createdAt is number;
    }

    match /users/{userId} {
      allow get: if isSignedIn() && isValidId(userId);
      allow list: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isSignedIn() && isValidId(userId) && userId == request.auth.uid &&
                    isValidUser(incoming(), true) && incoming().createdAt == request.time.toMillis();
      allow update: if isSignedIn() && isValidId(userId) && userId == request.auth.uid &&
                    isValidUser(incoming(), false) &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().uid == existing().uid &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['username', 'wins', 'losses', 'kills', 'deaths', 'rankPoints']);
      allow delete: if false;
    }
  }
}
